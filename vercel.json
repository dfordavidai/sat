{
  "routes": [
    { "src": "/sitemap.xml",         "dest": "/api/sitemap"             },
    { "src": "/feed.xml",            "dest": "/api/feed"                },
    { "src": "/link-hub",            "dest": "/api/link-hub"            },
    { "src": "/crawl-hub",           "dest": "/api/link-hub"            },
    { "src": "/link/(?<code>[^/]+)", "dest": "/api/redirect?code=$code" },

    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "www.flexygist.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "www.mp3fresh.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "mp3fresh.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "www.naijasturf.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "naijasturf.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "waecgceexpo.guruswapaz.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "jambexporuns.guruswapaz.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "www.guruswapaz.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "guruswapaz.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "jamb.guruswapaz.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "mp4videos.flexygist.com.ng" }] },
    { "src": "/(.*)", "headers": { "Location": "https://flexygist.com.ng/$1" }, "status": 301, "has": [{ "type": "host", "value": "mp3download.flexygist.com.ng" }] },

    { "src": "/(.*)", "dest": "/index.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/link/(.*)",
      "headers": [
        { "key": "X-Robots-Tag",  "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store"          }
      ]
    }
  ]
}
